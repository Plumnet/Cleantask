// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CleaningItem {
  id             String   @id @default(cuid())
  name           String
  frequency      Int
  lastCleanedAt  DateTime @db.Date
  nextCleaningAt DateTime @db.Date
  description    String?
  memo           String?
  imageFileName  String?
  warningStatus  String   @default("none")
  categoryIds    String[]
  consumableIds  String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  kaizenHistory KaizenRecord[]
  warningTask   WarningTask?
}

model KaizenRecord {
  id                String       @id @default(cuid())
  cleaningItemId    String
  cause             String
  previousFrequency Int
  newFrequency      Int
  createdAt         DateTime     @default(now())
  cleaningItem      CleaningItem @relation(fields: [cleaningItemId], references: [id], onDelete: Cascade)
}

model WarningTask {
  id                     String       @id @default(cuid())
  cleaningItemId         String       @unique
  kaizenRecordId         String
  consecutiveOnTimeCount Int          @default(0)
  startedAt              DateTime     @db.Date
  resolvedAt             DateTime?    @db.Date
  cleaningItem           CleaningItem @relation(fields: [cleaningItemId], references: [id], onDelete: Cascade)
}
